{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} | Inscriptions
{% endblock %}

{% block body %}
    <div class="gen-div-format">
        <h1 class="admin-h1">Inscriptions</h1>
        <div id="nav-div">
            {% include 'views/nav/navAdmin.html.twig' %}
        </div>
    </div>
    <div class="gen-div-format">
        <p class="required-field">* champs requis</p>
        {{ form_start(userRegistrationForm) }}
        {{ form_widget(userRegistrationForm) }}
        <div class="register-action-buttons-div">
            <button type="submit" class="register-action-buttons">Valider</button>
            <button type="reset" class="register-action-buttons" id="regis-cancel-btn">Annuler</button>
        </div>
        {{ form_end(userRegistrationForm) }}
    </div>
{% endblock %}

