{% extends 'base.html.twig' %}

{% block title %}
    <h1>Détails d'une sortie !</h1>
{% endblock %}

{% block body %}
    <div class="outing-details">
        <h2>{{ outing.name }}</h2>
        <div>Date et heure : {{ outing.startDateTime | date('Y/m/d')}}</div>
        <div>Date limite d'inscription : {{ outing.signupDateLimit | date('Y/m/d') }}</div>
        <div>Nombre de place : {{ outing.nbSignupsMax }}</div>
        <div>Durée : {{ outing.duration }}</div>
        <div>Description et infos : {{ outing.outingInfo }}</div>
        <div>Campus : {{ outing.campus }}</div>
        <div>Localisation : {{ outing.location }}</div>
        <div>Statu : {{ outing.status }}</div>
    </div>
{% endblock %}

